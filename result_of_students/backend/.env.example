# ── Copy this file to .env and fill in your values ───
# Never commit .env to version control

# PostgreSQL (local)
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/academia_db

# JWT
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000